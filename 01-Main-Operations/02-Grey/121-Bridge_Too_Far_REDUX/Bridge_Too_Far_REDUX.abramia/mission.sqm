														position[]={3780.5557,67.576645,-570.13513};
														angles[]={0,1.5707963,0};
													};
													side="Empty";
													flags=1;
													class Attributes
													{
														init="this setVariable [""down"", false];" \n "this setVariable [""animating"", false];";
														name="hangar_elevator";
													};
													id=8794;
													type="3AS_Sullust_Platform_Small_Arrow";
													atlOffset=15.779129;
												};
												class Item1
												{
													dataType="Object";
													class PositionInfo
													{
														position[]={3764.1807,52.927528,-581.63464};
														angles[]={0,0.052360009,0};
													};
													side="Empty";
													flags=5;
													class Attributes
													{
														init="this addAction  " \n "[ " \n " " \n """Elevator: DOWN"", " \n "{[-16.5] spawn (missionNamespace getVariable ""hangar_elevator_fnc"")}, " \n "nil,5000,true,true,"""", " \n """!(hangar_elevator getVariable 'down') && !(hangar_elevator getVariable 'animating')"",3 " \n " " \n "]; " \n " " \n "this addAction  " \n "[ " \n " " \n """Elevator: UP"", " \n "{[16.5] spawn (missionNamespace getVariable ""hangar_elevator_fnc"")}, " \n "nil,5000,true,true,"""", " \n """(hangar_elevator getVariable 'down') && !(hangar_elevator getVariable 'animating')"",3 " \n " " \n "];";
													};
													id=8795;
													type="3AS_Terminal_Short_Lever";
													atlOffset=0.15378189;
												};
												class Item2
												{
													dataType="Object";
													class PositionInfo
													{
														position[]={3798.6011,69.42453,-559.83875};
														angles[]={0,3.6128318,0};
													};
													side="Empty";
													flags=5;
													class Attributes
													{
														init="this addAction  " \n "[ " \n " " \n """Elevator: DOWN"", " \n "{[-16.5] spawn (missionNamespace getVariable ""hangar_elevator_fnc"")}, " \n "nil,5000,true,true,"""", " \n """!(hangar_elevator getVariable 'down') && !(hangar_elevator getVariable 'animating')"",3 " \n " " \n "]; " \n " " \n "this addAction  " \n "[ " \n " " \n """Elevator: UP"", " \n "{[16.5] spawn (missionNamespace getVariable ""hangar_elevator_fnc"")}, " \n "nil,5000,true,true,"""", " \n """(hangar_elevator getVariable 'down') && !(hangar_elevator getVariable 'animating')"",3 " \n " " \n "];";
													};
													id=8796;
													type="3AS_Terminal_Short_Lever";
												};
												class Item3
												{
													dataType="Logic";
													class PositionInfo
													{
														position[]={3799.1807,68.827133,-560.13464};
														angles[]={0,1.5707963,0};
													};
													name="elevator_functions";
													init="_hangar_elevator_fnc =   " \n "{  " \n "params [""_distance""];  " \n "  " \n "hangar_elevator setVariable [""animating"", true, true];  " \n "  " \n "_animation_time = 800;  " \n "_move_per_tick = _distance / _animation_time;  " \n "  " \n "_vehicles = vehicles select {_x inArea [(getPosASL hangar_elevator), 10,16,getDir hangar_elevator, true, 2,true]};  " \n "{  " \n " _dmg_allowed = isDamageAllowed _x; _x setVariable [""elevator_dmg_allowed_check"", _dmg_allowed, true];  " \n " _x setVariable [""elevator_stick_pos"", hangar_elevator worldToModelVisual (ASLToAGL (getPosASL _x)), true];  " \n " _x allowDamage false;  " \n "}forEach _vehicles;  " \n "  " \n "hangar_elevator say3d [""ls_door1_open"", 100, 0.2];  " \n "[]spawn  " \n "{  " \n "while {hangar_elevator getVariable ""animating""} do {hangar_elevator say3d [""ls_laat_ramp"", 100, (random [0.1,0.2,0.25])]; sleep random [1.5,2,3.5]};  " \n "};  " \n "  " \n "for ""_i"" from 1 to _animation_time do   " \n "{  " \n "_riding_array = allUnits select {_x inArea [(getPosASL hangar_elevator), 10,16,getDir hangar_elevator, true, 2,true]};  " \n "_riding_array = _riding_array + vehicles select {_x inArea [(getPosASL hangar_elevator), 10,16,getDir hangar_elevator, true, 2,true]};  " \n "_riding_array = _riding_array apply {[_x, hangar_elevator worldToModelVisual (ASLToAGL (getPosASL _x))]};  " \n "  " \n "hangar_elevator setPosASL (getPosASL hangar_elevator vectorAdd [0,0,_move_per_tick]);  " \n "{  " \n " _veh = (_x select 0); _offset = (_x select 1); if (isPlayer _veh) then {_offset = _offset vectorAdd [0,0,-0.05]};  " \n " if !(_veh isKindOf ""MAN"") then {_offset = (_veh getVariable ""elevator_stick_pos"")};  " \n " _world_pos = hangar_elevator modelToWorldVisualWorld _offset;  " \n " _veh setPosASL _world_pos;  " \n " _veh setVelocity [0,0,0];  " \n "}forEach _riding_array;  " \n "  " \n "sleep 0.01;  " \n "};  " \n "  " \n "{  " \n " _x allowDamage (_x getVariable [""elevator_dmg_allowed_check"", true]);  " \n "}forEach _vehicles;  " \n "  " \n "hangar_elevator setVariable [""animating"", false, true];  " \n "hangar_elevator setVariable [""down"", false, true];  " \n "if (_distance < 0) then {hangar_elevator setVariable [""down"", true, true]};  " \n "};  " \n "  " \n "missionNamespace setVariable [""hangar_elevator_fnc"", _hangar_elevator_fnc, true];";
													id=8797;
													type="Logic";
													atlOffset=0.0029983521;
												};
											};
											id=8793;
											atlOffset=14.481571;
										};
