						class Attribute2
						{
							property="ModuleCreateDiaryRecord_F_Description";
							expression="_this setVariable ['Description',_value,true];";
							class Value
							{
								class data
								{
									singleType="STRING";
									value="Author: Dr. Elias Varn (Senior Virology Division)" \n "Clearance Level: 4" \n "Timestamp: 23:47" \n "" \n "I’m documenting this in case containment fails completely." \n "" \n "Security protocols have become… unreliable. The automated lockdown initiated after the incident in Sublevel 3 has cut off primary access to the armoury. Manual override is required, but command codes are being cycled faster than we can authenticate." \n "" \n "As a precaution—no, as a necessity—I’ve relocated the current armoury access code to a more accessible location for surviving personnel." \n "" \n "The code has been stored within the cafeteria terminal system. Specifically, it’s embedded in the staff nutrition database under today’s meal rotation logs. I chose this location because it remains one of the few systems still accessible without Level 5 clearance, and, frankly, no one thinks to look there during a crisis.";
								};
							};
						};
						class Attribute3
						{
							property="ModuleCreateDiaryRecord_F_Owner";
							expression="_this setVariable ['Owner',_value,true];";
							class Value
							{
								class data
								{
									singleType="SCALAR";
									value=3;
								};
							};
						};
						class Attribute4
						{
							property="ModuleCreateDiaryRecord_F_Subject";
							expression="_this setVariable ['Subject',_value,true];";
							class Value
							{
								class data
								{
									singleType="STRING";
									value="Armoury Code";
								};
							};
						};
						nAttributes=5;
					};
				};
				class Item2
				{
					dataType="Object";
					class PositionInfo
