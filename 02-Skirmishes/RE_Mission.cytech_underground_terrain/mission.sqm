				class Attribute11
				{
					property="ITR_ModuleIntelSource_DiaryText";
					expression="_this setVariable ['DiaryText',_value,true];";
					class Value
					{
						class data
						{
							singleType="STRING";
							value="I don’t have time to make this sound official.  USS units have entered the facility perimeter. Internal comms confirm they are moving room-to-room and “clearing assets.” That’s what they’re calling it now. Assets.  If you’re still alive and reading this, do not attempt main corridors or upper service lifts. They are already compromised.  There is one route they likely haven’t prioritised yet: the Ore Extraction Plant.  It was never meant for personnel movement—just raw material transport—but the system still cycles on an independent rail network. That’s your window.";
						};
					};
				};
				nAttributes=12;
			};
		};
