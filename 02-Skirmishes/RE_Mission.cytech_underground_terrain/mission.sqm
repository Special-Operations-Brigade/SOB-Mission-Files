				class Attribute2
				{
					property="ModuleCreateDiaryRecord_F_Description";
					expression="_this setVariable ['Description',_value,true];";
					class Value
					{
						class data
						{
							singleType="STRING";
							value="Humans have used herbs to treat sickness and disease since the dawn of time. In this book, we will explore three such herbs native to the Arklay Mountains. " \n " " \n "Green herbs have the ability to heal basic injuries, while blue herbs have long been used to treat poisoning. " \n " " \n "As for red herbs, while they are visually appealing, they offer no medicinal benefits. Or so it was thought until recently. " \n " " \n "It's well-known that combining herbs together produces blends that heighten the herbs' effects, but it has been discovered that red herbs can play a big role when mixed properly. Combine herbs in your self interaction menu";
						};
					};
				};
				class Attribute3
				{
					property="ModuleCreateDiaryRecord_F_Owner";
					expression="_this setVariable ['Owner',_value,true];";
					class Value
					{
						class data
						{
							singleType="SCALAR";
							value=3;
						};
					};
				};
