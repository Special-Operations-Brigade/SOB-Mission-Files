				class Attribute11
				{
					property="ITR_ModuleIntelSource_DiaryText";
					expression="_this setVariable ['DiaryText',_value,true];";
					class Value
					{
						class data
						{
							singleType="STRING";
							value="The HELIOS platform was developed as a directed energy excitation system, designed to interact with viral structures at a cellular level—specifically strains derived from the T-Virus.  Unlike conventional weaponry, HELIOS does not destroy its target outright. Instead, it emits a focused energy beam calibrated to stimulate rapid mutation cycles within infected tissue.  The theory was simple: Force the virus to evolve faster than the host body can sustain, resulting in controlled destabilisation and eventual neutralisation.  The reality is… less predictable.";
						};
					};
				};
				nAttributes=12;
			};
		};
