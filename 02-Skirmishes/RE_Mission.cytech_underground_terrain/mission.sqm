			class Attributes
			{
				init="if (isServer) then { " \n "    this setVariable [""bis_disabled_Door_1"", 1, true]; " \n "    this animateSource [""Door_1_sound_source"", 0, true]; " \n "    { " \n "        _x setVariable [""PU_consoleUsed"", false, true]; " \n "    } forEach [Console1, Console2, Console3]; " \n "}; " \n "if (hasInterface) then { " \n "    private _door = this; " \n "    { " \n "        _x addAction [ " \n "            ""Activate Console"", " \n "            { " \n "                params [""_target"", ""_caller"", ""_actionId"", ""_door""]; " \n "                if (_target getVariable [""PU_consoleUsed"", false]) exitWith { " \n "                    hint ""This console is already activated.""; " \n "                }; " \n "                _target setVariable [""PU_consoleUsed"", true, true]; " \n "                _target removeAction _actionId; " \n "                private _count = { " \n "                    _x getVariable [""PU_consoleUsed"", false] " \n "                } count [Console1, Console2, Console3]; " \n "                if (_count >= 3) then { " \n "                    _door setVariable [""bis_disabled_Door_1"", 0, true]; " \n "                    _door animateSource [""Door_1_sound_source"", 1, true]; " \n "                    hint ""All 3 consoles activated. Door unlocked.""; " \n "                } else { " \n "                    hint format [""Console activated (%1/3)."", _count]; " \n "                }; " \n "            }, " \n "            _door, " \n "            1.5, " \n "            true, " \n "            true, " \n "            """", " \n "            ""!(_target getVariable ['PU_consoleUsed', false])"", " \n "            3 " \n "        ]; " \n "    } forEach [Console1, Console2, Console3]; " \n "};";
			};
			id=468;
			type="Land_Cyt_VerticalBlastDoor_08";
